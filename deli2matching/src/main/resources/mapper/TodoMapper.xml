<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.TodoMapper">

    <!-- ResultMap: DB 컬럼 -> Java 필드 매핑 -->
    <resultMap id="TodoResultMap" type="TodoEntity">
        <id     column="id"      property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title"   property="title"/>
        <result column="done"    property="done"/>
    </resultMap>

    <!-- INSERT: Todo 저장, useGeneratedKeys로 AUTO_INCREMENT PK 자동 세팅 -->
    <insert id="insert" parameterType="TodoEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO todo (user_id, title, done)
        VALUES (#{userId}, #{title}, #{done})
    </insert>

    <!-- SELECT: userId로 Todo 목록 조회 -->
    <select id="findByUserId" parameterType="Long" resultMap="TodoResultMap">
        SELECT id, user_id, title, done
        FROM todo
        WHERE user_id = #{userId}
    </select>

    <!-- SELECT: id로 단건 조회 -->
    <select id="findById" parameterType="Long" resultMap="TodoResultMap">
        SELECT id, user_id, title, done
        FROM todo
        WHERE id = #{id}
        LIMIT 1
    </select>

    <!-- UPDATE: title, done 수정 -->
    <update id="update" parameterType="TodoEntity">
        UPDATE todo
        SET title = #{title},
            done  = #{done}
        WHERE id = #{id}
    </update>

    <!-- DELETE: id로 삭제 -->
    <delete id="delete" parameterType="Long">
        DELETE FROM todo
        WHERE id = #{id}
    </delete>

</mapper>
