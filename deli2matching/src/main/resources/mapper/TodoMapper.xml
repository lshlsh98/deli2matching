<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.deli2matching.dao.TodoDao">

    <!-- INSERT: Todo 저장, useGeneratedKeys로 AUTO_INCREMENT PK 자동 세팅 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO todo (user_id, title, done)
        VALUES (#{userId}, #{title}, #{done})
    </insert>

    <!-- SELECT: userId로 Todo 목록 조회 -->
    <select id="findByUserId" resultType="com.example.deli2matching.entity.TodoEntity">
        SELECT id, user_id, title, done
        FROM todo
        WHERE user_id = #{userId}
    </select>

    <!-- SELECT: id로 단건 조회 -->
    <select id="findById" resultType="com.example.deli2matching.entity.TodoEntity">
        SELECT id, user_id, title, done
        FROM todo
        WHERE id = #{id}
        LIMIT 1
    </select>

    <!-- UPDATE: title, done 수정 -->
    <update id="update">
        UPDATE todo
        SET title = #{title},
            done  = #{done}
        WHERE id = #{id}
    </update>

    <!-- DELETE: id로 삭제 -->
    <delete id="delete">
        DELETE FROM todo
        WHERE id = #{id}
    </delete>

</mapper>
