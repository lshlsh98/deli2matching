# RDS (MySQL)
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
DB_USERNAME=admin
DB_PASSWORD=your-db-password

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-256-bits

# Email (Gmail SMTP)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password

# OAuth2 - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth2 - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# OAuth2 - Github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend - CloudFront or EC2 public IP
VITE_API_BASE_URL=https://your-cloudfront-domain.cloudfront.net
